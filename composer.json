{
    "name": "lolzteam/api",
    "description": "PHP API wrapper for Lolzteam Forum and Market",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "php-cs-fixer/shim": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Lolzteam\\": "src/"
        },
        "classmap": [
            "src/Generated/Forum/Models/",
            "src/Generated/Market/Models/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Lolzteam\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
